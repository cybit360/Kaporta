# =============================================================================
# Kaporta Group Website - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in actual values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Resend (Email Service)
# Used for contact form submissions and newsletter signups.
# Get your API key at https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here

# -----------------------------------------------------------------------------
# Site URL
# The public URL of the deployed website (no trailing slash).
# Used for generating absolute URLs in emails, OG images, and sitemaps.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://kaporta.vercel.app

# -----------------------------------------------------------------------------
# Google Maps API Key (Optional)
# Only needed if using the JavaScript Maps API for advanced map features.
# The basic embed map works without a key.
# Get a key at https://console.cloud.google.com/google/maps-apis
# -----------------------------------------------------------------------------
# GOOGLE_MAPS_API_KEY=your_key_here
